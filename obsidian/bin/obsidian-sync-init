#!/usr/bin/env bash
set -euo pipefail

LOCAL_VAULT="/home/fei/Documents/Obsidian Vault"
REMOTE_VAULT="gdrive:Obsidian Vault"
FILTERS="/home/fei/.config/rclone/obsidian-bisync-filter.txt"
WORKDIR="/home/fei/.cache/rclone/bisync-obsidian-vault"
LOCKDIR="/tmp/obsidian-sync.lock"

if ! mkdir "${LOCKDIR}" 2>/dev/null; then
  echo "已有 Obsidian 同步任务在运行，退出。"
  exit 1
fi
trap 'rmdir "${LOCKDIR}"' EXIT

if [[ ! -d "${LOCAL_VAULT}" ]]; then
  echo "本地 Vault 不存在：${LOCAL_VAULT}"
  exit 1
fi

if [[ ! -f "${FILTERS}" ]]; then
  echo "过滤规则不存在：${FILTERS}"
  exit 1
fi

cat <<EOF
即将重建 Obsidian Vault 的 rclone bisync 状态。

这不是日常同步命令；日常同步请使用 obsidian-sync。

Path1 本地：${LOCAL_VAULT}
Path2 云端：${REMOTE_VAULT}

警告：本命令会执行 rclone bisync --resync。
Path1 本地文件可能覆盖 Path2 云端版本。
只有在你已经确认本地 Vault 是可信基线，或已手动合并本地和云端差异后，才继续。
EOF

printf '请输入 y 继续，其他输入取消：'
if ! read -r confirm; then
  echo "已取消 Obsidian 同步状态重建。"
  exit 1
fi

if [[ ! "${confirm}" == "y" ]]; then
  echo "已取消 Obsidian 同步状态重建。"
  exit 1
fi

mkdir -p "${WORKDIR}"

rclone bisync "${LOCAL_VAULT}" "${REMOTE_VAULT}" \
  --resync \
  --workdir "${WORKDIR}" \
  --filters-file "${FILTERS}" \
  --verbose
