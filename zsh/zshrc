export LANG='en_US.UTF-8'
export LANGUAGE='en_US:en'
export LC_ALL='en_US.UTF-8'
export TERM=xterm-256color

##### Zsh/Oh-my-Zsh Configuration
export ZSH="$HOME/.oh-my-zsh"

DISABLE_AUTO_UPDATE="true"
DISABLE_UPDATE_PROMPT="true"

ZSH_THEME="ys"
plugins=(
    git
    vi-mode
    zsh-autosuggestions
    zsh-completions
    zsh-syntax-highlighting
    autojump
    fzf
)


source $ZSH/oh-my-zsh.sh
export PATH="$PATH:/usr/bin/"
export PATH="$PATH:/usr/include/"

alias gs="git status"
alias s="tmux"
alias vim='nvim'
alias typora="open -a typora"

alias dkps="docker ps"
alias dkpa="docker ps -a"
alias dki="docker images"
alias dka="docker attach"
alias dkrm='docker rm'
alias dkrmi='docker rmi'

export MYZSHRC="$HOME/.zshrc"
export MYTMUXCONF="$HOME/.tmux.conf"

export VISUAL=nvim
export EDITOR=nvim

unsetopt nomatch

# for gfw
# export http_proxy="http://127.0.0.1:7890"
# export https_proxy="http://127.0.0.1:7890"

# for ros1 noetic
# alias cw='cd ~/catkin_ws'
# alias cs='cd ~/catkin_ws/src'
# alias cm='cd ~/catkin_ws && catkin build'
# source ~/catkin_ws/devel/setup.zsh
# source /opt/ros/noetic/setup.zsh

# export ROS_HOSTNAME=ly_slave
# export ROS_MASTER_URI=http://ly_master:11311
# export ROS_HOSTNAME=localhost
# export ROS_MASTER_URI=http://localhost:11311

# for ros2 jazzy
if [[ -f /opt/ros/jazzy/setup.zsh ]]; then
    source /opt/ros/jazzy/setup.zsh
fi

if [[ -f "$HOME/ros2_ws/install/setup.zsh" ]]; then
    source "$HOME/ros2_ws/install/setup.zsh"
fi

export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/dev_env/bin:$PATH"
if command -v register-python-argcomplete >/dev/null 2>&1 && command -v ros2 >/dev/null 2>&1; then
    eval "$(register-python-argcomplete ros2)"
fi

if command -v register-python-argcomplete >/dev/null 2>&1 && command -v colcon >/dev/null 2>&1; then
    eval "$(register-python-argcomplete colcon)"
fi
alias cw='cd ~/ros2_ws'
alias cs='cd ~/ros2_ws/src'
alias cm='cd ~/ros2_ws && colcon build --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON --symlink-install'
alias denv='source ~/dev_env/bin/activate'
export NVIM_PYTHON_VENV="$HOME/dev_env"

# export ROSCONSOLE_FORMAT='[${severity}] [${time}] [${node}]: ${message}'
export LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH

# export TURTLEBOT3_MODEL=waffle
# export GAZEBO_MODEL_PATH=$GAZEBO_MODEL_PATH:/opt/ros/humble/share/turtlebot3_gazebo/models
export GAZEBO_MODEL_PATH=$GAZEBO_MODEL_PATH:$HOME/.gazebo/models
